    {
      "id": "a1b2c3d4-0003-0003-0003-000000000003",
      "name": "Check 30-Day Dedup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300],
      "parameters": {
        "jsCode": "const trigger = $('New Lead Added').first().json;\nconst company = (trigger.Company || '').trim();\nconst cutoff = Date.now() - (30 * 24 * 60 * 60 * 1000);\n\nlet isRecent = false;\nconst rows = $input.all();\n\nif (rows && rows.length > 0 && rows[0].json && rows[0].json.Company) {\n  isRecent = rows.some(row => {\n    const rowCompany = (row.json.Company || '').trim();\n    if (rowCompany.toLowerCase() !== company.toLowerCase()) return false;\n    if (!row.json.Recency) return false;\n    return new Date(row.json.Recency).getTime() > cutoff;\n  });\n}\n\nreturn [{\n  json: {\n    isRecent,\n    company,\n    website: trigger.Website || '',\n    contactName: trigger['Contact Name'] || '',\n    role: trigger.Role || '',\n    email: trigger.Email || ''\n  }\n}];"
      }
    },
    {
      "id": "a1b2c3d4-0004-0004-0004-000000000004",
      "name": "Skip If Recent",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-dedup",
              "leftValue": "={{ $json.isRecent }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equal"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
