    {
      "id": "a1b2c3d4-0007-0007-0007-000000000007",
      "name": "Summarizer Chain",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.4,
      "position": [1560, 200],
      "parameters": {
        "promptType": "define",
        "text": "=`You are a business analyst researching prospective consulting clients.\n\nCompany: ${ $('New Lead Added').first().json.Company }\nWebsite: ${ $('New Lead Added').first().json.Website }\n\nWebsite Content:\n${ String($('Scrape Website').first().json.data || '').slice(0, 3000) }\n\nRecent News Headlines:\n${ String($('Fetch News').first().json.data || '').slice(0, 1500) }\n\nWrite a 2-3 sentence factual summary covering: what this company does, who their customers are, and their current operational focus. Output only the summary — no labels, headers, or extra commentary.`"
      }
    },
