        "text": "={{ 'You are a business analyst researching prospective consulting clients.\\n\\nCompany: ' + $json.company + '\\nWebsite: ' + $json.website + '\\n\\nWebsite Content:\\n' + String($json.content || '').slice(0, 3000) + '\\n\\nRecent News Headlines:\\n' + String($json.news || '').slice(0, 1500) + '\\n\\nWrite a 2-3 sentence factual summary covering: what this company does, who their customers are, and their current operational focus. Output only the summary — no labels, headers, or extra commentary.' }}"
